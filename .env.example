# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit your real keys.

# From Supabase → Settings → API → Project URL
VITE_SUPABASE_URL=https://xbsayrgetkksafctmewm.supabase.co

# From Supabase → Settings → API → anon public key (NOT the service_role key)
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Local offline PIN — shown on the login page when Supabase is unavailable
VITE_LOCAL_PIN=your-local-pin-here
